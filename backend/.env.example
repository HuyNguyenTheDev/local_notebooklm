# ===== Supabase =====
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct PostgreSQL (for pgvector queries via asyncpg)
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# ===== External APIs =====
LLM_API_URL=https://xxxx.ngrok-free.app/generate
EMBEDDING_API_URL=https://xxxx.ngrok-free.app/embed
PDF_PARSE_API_URL=

# ===== Chunking =====
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ===== Vector =====
EMBEDDING_DIM=1024
EMBED_MODEL=BAAI/bge-m3
